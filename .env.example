# ============================================================
#  GateGuard Configuration
#  Copy this file to .env and edit the values.
#  cp .env.example .env
# ============================================================

# ── Camera ──────────────────────────────────────────────────
# RTSP URL of the IP camera pointed at the gate
RTSP_URL=rtsp://admin:password@192.168.1.100:554/Streaming/Channels/101

# ── ESP32 Alarm Module ──────────────────────────────────────
# IP address of the ESP32 running esp32_relay.ino
ESP32_IP=192.168.1.50

# ── Databases ───────────────────────────────────────────────
# Path to the Moonwell MW-305 Access database (read-only)
MDB_PATH=moonwel_db/MW305_DB200.mdb

# Local SQLite database (auto-created on first run)
SQLITE_PATH=data/gateguard.db

# ── Screenshots ─────────────────────────────────────────────
SCREENSHOT_DIR=static/screenshots

# ── Detection ───────────────────────────────────────────────
# false = Live mode (real camera + ESP32)
# true  = Test mode (fake camera, no hardware needed)
MOCK_MODE=false

# Frames analyzed per second (1-5, higher = more CPU)
PROCESS_FPS=2

# Minimum per-frame confidence to accept a plate reading (0.0-1.0)
CONFIDENCE_THRESHOLD=0.45

# Seconds before the same plate can trigger another alarm
ALARM_COOLDOWN_SEC=60

# Levenshtein distance tolerance for fuzzy DB lookup (0=exact only)
FUZZY_TOLERANCE=1

# ── Track-based multi-frame consensus ──────────────────────
# A passage is committed only after the vehicle leaves the view.
# Minimum valid OCR readings required before committing a passage.
MIN_FRAMES_FOR_COMMIT=2
# Consecutive missed frames before a track finalizes.
TRACK_IDLE_FRAMES=2
# Force-close tracks that exceed this duration (seconds).
TRACK_MAX_DURATION_SEC=15
# Bbox IoU required to associate a detection with an active track.
TRACK_IOU_THRESHOLD=0.2
# Fuzzy plate text tolerance for cross-frame association (handles OCR variance).
TRACK_FUZZY_TOLERANCE=2
# Minimum bbox area ratio to classify direction by size change.
DIRECTION_AREA_RATIO=1.2

# ── LPR Engine ──────────────────────────────────────────────
# "fast_alpr"    — Best accuracy (96%). Built-in detector + OCR. Recommended.
# "yolo_easyocr" — Custom YOLO plate detector + EasyOCR. Needs trained weights.
# "easyocr"      — OpenCV contours + EasyOCR. No extra setup. Low accuracy.
LPR_ENGINE=fast_alpr

# Only needed if LPR_ENGINE=yolo_easyocr
YOLO_WEIGHTS=models/plate_detector.pt

# ── Entry/Exit direction detection (single camera) ─────────
# Primary signal: bbox area change
#   "approach" = plate growing (vehicle approaching camera) = ENTRY
#                Typical gate camera looking outward at arrivals.
#   "recede"   = plate shrinking (vehicle moving away) = ENTRY
#                Camera inside the lot looking at the entrance — vehicles entering
#                pass the camera and drive away into the parking area.
CAMERA_ENTRY_SIZE_CHANGE=approach

# Fallback when area change is ambiguous (< ratio threshold):
#   "down" = plate moving DOWN in frame = ENTRY
#   "up"   = plate moving UP in frame = ENTRY
CAMERA_ENTRY_Y_DIRECTION=down

# ── Module 2: Intrusion / Hırsızlık Tespiti ──────────────
# Enable the multi-camera person detection module.
# Cameras themselves are registered via web UI and stored in the database
# (not configured here). This is just the feature toggle.
ENABLE_INTRUSION_MODULE=false

# Night mode: used by zones marked "night only" (is_night_only=1).
# Outside this window those zones do not trigger alarms.
NIGHT_MODE_START=22:00
NIGHT_MODE_END=07:00

# Detection thresholds — tuned for high recall + low false-positive.
# Lower per-frame confidence is paired with a frame-count consensus rule:
# alarm fires only after the same track is seen in N consecutive frames,
# so single-frame flicker (shadow, glint, mannequin) cannot trigger.
INTRUSION_CONFIDENCE=0.30
INTRUSION_MIN_LOITER_SEC=1
INTRUSION_COOLDOWN_SEC=30
INTRUSION_PROCESS_FPS=2
INTRUSION_WARMUP_SEC=30
# Frame-count consensus (3 frames @ 2 FPS ≈ 1.5 s of confirmed presence)
INTRUSION_MIN_CONSECUTIVE_FRAMES=3
# If gap between observations exceeds this, the counter resets
INTRUSION_FRAME_GAP_RESET_SEC=3.0

# Shadow mode: log events to DB without triggering the physical siren.
# Recommended for the first week of deployment to tune parameters.
INTRUSION_SHADOW_MODE=true

# Person detection model (auto-downloaded by ultralytics on first run)
YOLO_PERSON_MODEL=yolov8n.pt
YOLO_PERSON_TRACKER=bytetrack.yaml
USE_GPU_FOR_PERSON=false

# Evidence capture: MP4 clip + burst screenshots
INTRUSION_CLIP_ENABLED=true
INTRUSION_CLIP_PRE_SEC=10
INTRUSION_CLIP_POST_SEC=5
INTRUSION_CLIP_DIR=static/intrusion_clips
INTRUSION_BURST_SCREENSHOTS=5
INTRUSION_RETENTION_DAYS=60

# ── General ─────────────────────────────────────────────────
LOG_LEVEL=INFO
