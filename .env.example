# ============================================================
#  GateGuard Configuration
#  Copy this file to .env and edit the values.
#  cp .env.example .env
# ============================================================

# ── Camera ──────────────────────────────────────────────────
# RTSP URL of the IP camera pointed at the gate
RTSP_URL=rtsp://admin:password@192.168.1.100:554/Streaming/Channels/101

# ── ESP32 Alarm Module ──────────────────────────────────────
# IP address of the ESP32 running esp32_relay.ino
ESP32_IP=192.168.1.50

# ── Databases ───────────────────────────────────────────────
# Path to the Moonwell MW-305 Access database (read-only)
MDB_PATH=moonwel_db/MW305_DB200.mdb

# Local SQLite database (auto-created on first run)
SQLITE_PATH=data/gateguard.db

# ── Screenshots ─────────────────────────────────────────────
SCREENSHOT_DIR=static/screenshots

# ── Detection ───────────────────────────────────────────────
# false = Canlı mod (gerçek kamera + ESP32 kullanır)
# true  = Test modu (sahte kamera, donanım gerekmez — sadece geliştirme için)
MOCK_MODE=false

# Frames analyzed per second (1-5, higher = more CPU)
PROCESS_FPS=2

# Minimum OCR confidence to accept a plate reading (0.0-1.0)
CONFIDENCE_THRESHOLD=0.4

# Seconds before the same plate can trigger another alarm
ALARM_COOLDOWN_SEC=60

# Levenshtein distance tolerance for fuzzy plate matching (0=exact only)
FUZZY_TOLERANCE=1

# ── YOLOv8 (optional) ──────────────────────────────────────
# Set USE_YOLO=true after training a custom model
USE_YOLO=false
YOLO_WEIGHTS=models/plate_detector.pt

# ── General ─────────────────────────────────────────────────
LOG_LEVEL=INFO
